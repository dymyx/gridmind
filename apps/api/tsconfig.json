{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./build",

		"module": "commonjs",
		"target": "es2020",
		"paths": {
			"@gridmind/types": ["../../packages/types/src/"]
		},

		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		"esModuleInterop": true,

		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,

		"strict": true,
		"isolatedModules": true,
		"skipLibCheck": true
	}
}
